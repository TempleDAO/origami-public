{
  "name": "temple-automation",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "prepare": "yarn typechain",
    "typechain": "typechain --target=ethers-v5 --out-dir src/typechain abi/*.json",
    "lint": "eslint --max-warnings=0 src",
    "test": "mocha ./test/**/*.test.ts",
    "clean": "rm -rf dist",
    "build:transfer-staked-glp:mumbai": "yarn clean && ROLLUP_INPUT=./src/transfer-staked-glp/mumbai.ts rollup --config ./rollup.config.mjs",
    "deploy:transfer-staked-glp:mumbai": "yarn build:transfer-staked-glp:mumbai && defender-autotask update-code 25a66f4c-b888-44da-b3e6-6fa77dd87f5b ./dist && echo 'View at https://defender.openzeppelin.com/#/autotask/25a66f4c-b888-44da-b3e6-6fa77dd87f5b'",
    "build:transfer-staked-glp-alert:mumbai": "yarn clean && ROLLUP_INPUT=./src/transfer-staked-glp-alert/mumbai.ts rollup --config ./rollup.config.mjs",
    "deploy:transfer-staked-glp-alert:mumbai": "yarn build:transfer-staked-glp-alert:mumbai && defender-autotask update-code 5d0a8599-2314-489a-9e98-e534df4a6bb8 ./dist && echo 'View at https://defender.openzeppelin.com/#/autotask/5d0a8599-2314-489a-9e98-e534df4a6bb8'"
  },
  "devDependencies": {
    "@datadog/datadog-api-client": "^1.0.0-beta.5",
    "@ethersproject/abi": "^5.0.0",
    "@ethersproject/abstract-provider": "^5.5.1",
    "@ethersproject/abstract-signer": "^5.6.2",
    "@ethersproject/bignumber": "^5.5.0",
    "@ethersproject/bytes": "^5.0.0",
    "@ethersproject/hash": "^5.6.1",
    "@ethersproject/properties": "^5.5.0",
    "@ethersproject/providers": "^5.6.8",
    "@ethersproject/transactions": "^5.6.2",
    "@gnosis.pm/safe-core-sdk": "^0.3.1",
    "@gnosis.pm/safe-ethers-adapters": "^0.1.0-alpha.3",
    "@rollup/plugin-commonjs": "^23.0.3",
    "@rollup/plugin-json": "^5.0.2",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-typescript": "^10.0.1",
    "@typechain/ethers-v5": "^10.1.1",
    "@types/chai": "^4.3.4",
    "@types/estree": "^1.0.0",
    "@types/mocha": "^10.0.1",
    "axios": "^0.21.2",
    "axios-retry": "3.1.9",
    "builtin-modules": "^3.3.0",
    "chai": "^4.3.7",
    "defender-admin-client": "1.37.0-rc.2",
    "defender-autotask-client": "^1.37.0",
    "defender-autotask-utils": "1.34.0",
    "defender-kvstore-client": "1.37.0-rc.2",
    "defender-relay-client": "1.37.0-rc.2",
    "defender-sentinel-client": "1.37.0-rc.2",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^8.5.0",
    "ethers": "5.5.3",
    "fireblocks-sdk": "^2.3.2",
    "graphql": "^15.5.1",
    "graphql-request": "3.4.0",
    "lint-staged": "^13.0.4",
    "mocha": "^10.1.0",
    "rollup": "^3.5.0",
    "typechain": "^8.1.1",
    "typescript": "^4.9.4",
    "web3": "1.3.6",
    "web3-core": "^1.7.3",
    "web3-core-helpers": "^1.7.3"
  },
  "dependencies": {
    "@types/node": "^18.11.10",
    "@types/qs": "^6.9.7",
    "qs": "^6.11.0",
    "ts-node": "^10.9.1"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --cache --fix"
    ],
    "*.{html,css}": [
      "prettier --write"
    ]
  }
}
